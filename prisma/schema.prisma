generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  walletAddress    String        @unique
  username         String?       @unique
  bio              String?
  avatarUrl        String?
  worldIdVerified  Boolean       @default(false)
  worldIdNullifier String?       @unique
  notifyPlatform   Boolean       @default(true)
  notifyTelegram   String?
  notifyEmail      String?
  notifyTime       String        @default("09:00")
  timezone         String        @default("UTC")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  commitments      Commitment[]  @relation("MakerCommitments")
  beliefs          Belief[]
  comments         Comment[]
  coachMessages    CoachMessage[]
  followers        Follow[]      @relation("Followers")
  following        Follow[]      @relation("Following")
  reactions        Reaction[]
}

model Commitment {
  id                  String             @id @default(cuid())
  onchainAddress      String?            @unique
  onchainTxSig        String?
  slug                String             @unique
  title               String
  description         String?
  category            CommitmentCategory
  proofType           ProofType
  coachTone           CoachTone          @default(SUPPORTIVE_FRIEND)
  stakeAmountLamports BigInt
  slashDestination    SlashDest          @default(TREASURY)
  startDate           DateTime
  endDate             DateTime
  totalDays           Int
  requiredProofDays   Int
  status              CommitmentStatus   @default(ACTIVE)
  isPublic            Boolean            @default(true)
  proofCount          Int                @default(0)
  completionRatio     Float?
  resolvedAt          DateTime?
  makerId             String
  maker               User               @relation("MakerCommitments", fields: [makerId], references: [id])
  proofs              Proof[]
  beliefs             Belief[]
  comments            Comment[]
  coachMessages       CoachMessage[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([makerId])
  @@index([status])
  @@index([isPublic])
  @@index([slug])
}

model Proof {
  id            String     @id @default(cuid())
  commitmentId  String
  commitment    Commitment @relation(fields: [commitmentId], references: [id])
  dayNumber     Int
  textContent   String?
  imageUrl      String?
  linkUrl       String?
  contentHash   String?
  onchainTxSig  String?
  publicNote    String?
  createdAt     DateTime   @default(now())
  reactions     Reaction[]

  @@unique([commitmentId, dayNumber])
  @@index([commitmentId])
}

model Belief {
  id                   String       @id @default(cuid())
  commitmentId         String
  commitment           Commitment   @relation(fields: [commitmentId], references: [id])
  believerId           String
  believer             User         @relation(fields: [believerId], references: [id])
  stakeAmountLamports  BigInt
  onchainAddress       String?
  onchainTxSig         String
  status               BeliefStatus @default(ACTIVE)
  settledAt            DateTime?
  createdAt            DateTime     @default(now())

  @@unique([commitmentId, believerId])
  @@index([commitmentId])
}

model CoachMessage {
  id            String       @id @default(cuid())
  commitmentId  String
  commitment    Commitment   @relation(fields: [commitmentId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  role          MessageRole
  content       String
  dayNumber     Int?
  trigger       CoachTrigger
  createdAt     DateTime     @default(now())

  @@index([commitmentId])
}

model Comment {
  id            String     @id @default(cuid())
  commitmentId  String
  commitment    Commitment @relation(fields: [commitmentId], references: [id])
  authorId      String
  author        User       @relation(fields: [authorId], references: [id])
  content       String
  createdAt     DateTime   @default(now())
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Reaction {
  id        String        @id @default(cuid())
  proofId   String
  proof     Proof         @relation(fields: [proofId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  type      ReactionType
  createdAt DateTime      @default(now())

  @@unique([proofId, userId, type])
  @@index([proofId])
  @@index([userId])
}

enum CommitmentCategory {
  FITNESS
  LEARNING
  CREATIVE
  WORK
  HEALTH
  FINANCIAL
  CUSTOM
}

enum ProofType {
  TEXT
  PHOTO
  LINK
  GITHUB_COMMIT
  CUSTOM
}

enum SlashDest {
  BURN
  DONATE
  TREASURY
}

enum CommitmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABANDONED
}

enum BeliefStatus {
  ACTIVE
  WON
  LOST
}

enum MessageRole {
  COACH
  USER
}

enum CoachTone {
  DRILL_SERGEANT
  SUPPORTIVE_FRIEND
  NEUTRAL_ANALYST
}

enum CoachTrigger {
  DAILY_CHECKIN
  PROOF_SUBMITTED
  STREAK_RISK
  MILESTONE
  COMPLETION
  FAILURE
}

enum ReactionType {
  MOMENTUM
  STREAK
  WATCHING
  DOUBT
}
