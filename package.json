{
  "name": "oath-markets",
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-test": "cd anchor && anchor test --skip-deploy",
    "build": "pnpm exec prisma generate && next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "codama:js": "codama run js",
    "codama:oath": "codama -c codama-oath.json run js",
    "dev": "next dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "setup": "npm run anchor-build && npm run codama:oath",
    "start": "next start"
  },
  "description": "Next.js, Tailwind, @solana/kit, Anchor vault program",
  "keywords": [
    "anchor",
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "6.19.3",
    "@solana/kit": "^6.3.0",
    "@solana/kit-client-rpc": "^0.7.0",
    "@solana/kit-plugin-rpc": "^0.7.0",
    "@solana/wallet-standard-features": "^1.3.0",
    "@tanstack/react-query": "^5.100.9",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "prisma": "6.19.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "swr": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
